{
  "name": "redux-firefly",
  "version": "1.0.0",
  "description": "Redux middleware for persisting state to SQLite in React Native",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.esm.js",
      "require": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./toolkit": {
      "import": "./dist/toolkit.esm.js",
      "require": "./dist/toolkit.js",
      "types": "./dist/toolkit.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "expo-sqlite": "^14.0.0 || ^15.0.0",
    "react": "^18.0.0",
    "react-redux": "^8.0.0 || ^9.0.0",
    "redux": "^4.0.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "@reduxjs/toolkit": {
      "optional": true
    }
  },
  "devDependencies": {
    "@reduxjs/toolkit": "^2.0.0",
    "@eslint/js": "^9.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "expo-sqlite": "^15.0.0",
    "jest": "^29.0.0",
    "react": "^18.0.0",
    "react-redux": "^9.0.0",
    "redux": "^5.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "ts-jest": "^29.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "keywords": [
    "redux",
    "middleware",
    "sqlite",
    "react-native",
    "expo",
    "persistence",
    "offline",
    "firefly"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
